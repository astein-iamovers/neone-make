:9999  # Caddy listens on port 9999

log {
    output stdout
    level DEBUG
}

# Rewrite all requests to the specified Make webhook path
rewrite * /{MAKE_WEBHOOK_PATH}

# Reverse proxy to the Make.com webhook
reverse_proxy {MAKE_WEBHOOK_HOST} {
    method POST    
    header_up Host {upstream_hostport}
}
