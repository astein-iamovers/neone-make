:9999  # Caddy listens on port 9999

log {   # Enable logging for debugging
    output stdout
    level DEBUG
}

# Directly proxy all requests to the Make webhook URL from the environment variable
reverse_proxy {env.MAKE_WEBHOOK_URL} {
    header_up Host {http.reverse_proxy.upstream.hostport}
    header_up X-Forwarded-For {remote}
    method POST
}
