# Your ONE Record Server Hostname (without protocol and port)
HOST=
# Your notification endpoint. If running the Flask app this would be http://HOST:5000 (replace baseUrl with he corresponding value)
NOTIFICATION_ENDPOINT=
# Name for your organization (it can be changed later with the API)
DATA_HOLDER_NAME=My Organization

# Authentication Variables
AUTH_SERVER=https://dev-8sdrqcf4lrnuavi4.us.auth0.com
CLIENT_ID=
CLIENT_SECRET=
AUDIENCE=

# If you are using the Flask app to fetch events you'll need the authentication token
JWT_TOKEN=

# If you are using the Flask app to forward events to an Airtable webhook:
MAKE_WEBHOOK_URL=
